{
  "name": "farmtracks",
  "private": true,
  "version": "1.0.6",
  "main": "desktop/main.cjs",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "desktop": "npm run build && electron ./desktop/main.cjs",
    "desktop:dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\" \"wait-on tcp:3001 http://127.0.0.1:5173 && electron ./desktop/main.cjs\"",
    "desktop:installer": "npm run build && electron-builder --win nsis",
    "release:exe": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-release.ps1",
    "release:exe:no-build": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-release.ps1 -SkipBuild",
    "preview": "npm run preview --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "screenshot-desktop": "^1.15.4",
    "tesseract.js": "^7.0.0"
  },
  "build": {
    "appId": "com.vision4.farmtracks",
    "productName": "FarmTracks Overlay",
    "artifactName": "FarmTracks-Overlay-Setup.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "client/dist/**/*",
      "server/**/*",
      "package.json"
    ],
    "asar": true,
    "protocols": [
      {
        "name": "FarmTracks Overlay",
        "schemes": [
          "farmtracks"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "client/public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
